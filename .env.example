# QueryMind — Environment Variables

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL 
DB_HOST=localhost
DB_PORT=5432
DB_USER=querymind
DB_PASSWORD=querymind_secret
DB_NAME=querymind
DB_URL=postgresql://querymind:querymind_secret@localhost:5432/querymind

# Agent Configuration
MAX_RETRIES=3
RESULT_LIMIT=500

# Embedding Model
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIMENSION=384

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5000
BACKEND_URL=http://localhost:8000
